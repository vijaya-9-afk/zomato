pipeline {
    agent any

    environment {
        IMAGE_NAME = 'zomato1'
        IMAGE_TAG  = 'v1'
    }

    tools {
        jdk 'jdk17'
    }

    stages {

        stage ("Clean Workspace") {
            steps {
                cleanWs()
            }
        }

        stage ("Git Checkout") {
            steps {
                git branch: 'main', url: 'https://github.com/vijaya-9-afk/zomato.git'
            }
        }

        stage ("Build Docker Image") {
            steps {
                sh "docker build -t ${IMAGE_NAME}:${IMAGE_TAG} ."
            }
        }

        stage ("Deploy to Container") {
            steps {
                sh """
                    docker stop zomato_container || true
                    docker rm zomato_container || true
                    docker run -d -p 3006:3000 --name zomato_container ${IMAGE_NAME}:${IMAGE_TAG}
                """
            }
        }
    }
}
